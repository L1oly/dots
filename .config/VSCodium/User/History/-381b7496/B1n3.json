[dark]
# Material 3 Design Tokens
material_color_primary = "{{colors.dark.primary.hex}}"
material_color_on_primary = "{{colors.dark.on_primary.hex}}"
material_color_secondary = "{{colors.dark.secondary.hex}}"
material_color_on_secondary = "{{colors.dark.on_secondary.hex}}"
material_color_tertiary = "{{colors.dark.tertiary.hex}}"
material_color_on_tertiary = "{{colors.dark.on_tertiary.hex}}"
material_color_error = "{{colors.dark.error.hex}}"
material_color_on_error = "{{colors.dark.on_error.hex}}"
material_color_surface = "{{colors.dark.surface.hex}}"
material_color_on_surface = "{{colors.dark.on_surface.hex}}"
material_color_surface_variant = "{{colors.dark.surface_variant.hex}}"
material_color_on_surface_variant = "{{colors.dark.on_surface_variant.hex}}"
material_color_outline = "{{colors.dark.outline.hex}}"
material_color_shadow = "{{colors.dark.shadow.hex}}"

# Custom App Tokens
custom_color_hover = "{{colors.dark.primary.hex}}"
custom_color_on_hover = "{{colors.dark.on_primary.hex}}"

# Terminal Configuration
terminal_background = "{{colors.dark.surface_container.hex}}"
terminal_foreground = "{{colors.dark.on_surface.hex}}"
terminal_cursor = "{{colors.dark.primary.hex}}"
terminal_cursor_text = "{{colors.dark.surface_container.hex}}"
terminal_selection_bg = "{{colors.dark.primary_container.hex}}"
terminal_selection_fg = "{{colors.dark.on_primary_container.hex}}"

# Terminal Normal Colors (ANSI 0-7)
terminal_ansi_black = "{{colors.dark.surface_container_high.hex}}"
terminal_ansi_red = "{{colors.dark.error.hex}}"
terminal_ansi_green = "{{colors.dark.tertiary.hex}}"
terminal_ansi_yellow = "{{colors.dark.inverse_primary.hex}}"
terminal_ansi_blue = "{{colors.dark.primary.hex}}"
terminal_ansi_magenta = "{{colors.dark.secondary.hex}}"
terminal_ansi_cyan = "{{colors.dark.outline_variant.hex}}"
terminal_ansi_white = "{{colors.dark.on_surface.hex}}"

# Terminal Bright Colors (ANSI 8-15)
terminal_ansi_bright_black = "{{colors.dark.outline.hex}}"
terminal_ansi_bright_red = "{{colors.dark.error_container.hex}}"
terminal_ansi_bright_green = "{{colors.dark.tertiary_container.hex}}"
terminal_ansi_bright_yellow = "{{colors.dark.scrim.hex}}"
terminal_ansi_bright_blue = "{{colors.dark.secondary_container.hex}}"
terminal_ansi_bright_magenta = "{{colors.dark.primary_container.hex}}"
terminal_ansi_bright_cyan = "{{colors.dark.outline_variant.hex}}"
terminal_ansi_bright_white = "{{colors.dark.surface_dim.hex}}"


